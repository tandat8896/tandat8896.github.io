              <p class="mt-2 text-sm text-muted-foreground">{demo.description}</p>
              <div class="mt-4 overflow-hidden rounded-xl border border-border bg-muted/30 shadow-sm transition-transform duration-300 hover:scale-[1.01]">
                <iframe
                  class="block aspect-video w-full"
                  src={demo.embed}
                  title={`${demo.title} video`}
                  loading="lazy"
                  referrerpolicy="strict-origin-when-cross-origin"
                  allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                  allowfullscreen
                ></iframe>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section id="projects" class="reveal-block border-y border-border bg-muted/20">

        <h2 class="text-3xl font-bold">Dự án nổi bật</h2>
        <p class="mt-2 max-w-2xl text-muted-foreground">
          Bản tóm tắt nhanh các dự án chính. Phần chi tiết kỹ thuật đã được gom vào mục mở rộng trong từng card.
        </p>

        <div class="mt-8 grid gap-5 lg:grid-cols-2">
          {featuredProjects.map((project, index) => (
            <article class="neo-panel project-card rounded-xl border border-border/90 bg-background/92 p-5 transition-all duration-200" style={`--stagger-index: ${index};`}>
              <div class="flex items-start justify-between gap-3">
                <h3 class="text-xl font-semibold">{project.title}</h3>
                <span class:list={[
                  "rounded-full border px-2 py-1 text-[10px] font-semibold uppercase tracking-wide",
                  project.state === "In Progress"
                    ? "border-amber-500/50 bg-amber-100 text-amber-700"
                    : project.state === "Competition"
                      ? "border-violet-500/40 bg-violet-100 text-violet-700"
                      : "border-emerald-500/40 bg-emerald-100 text-emerald-700",
                ]}>
                  {project.state}
                </span>
              </div>
              <p class="mt-1 text-xs font-semibold uppercase tracking-wide text-accent">{project.role}</p>
              <p class="mt-3 text-sm leading-relaxed text-muted-foreground">{project.description}</p>

              <div class="mt-4 flex flex-wrap gap-2">
                {project.stack.map(tech => (
                  <span class="neo-pill rounded-full border border-border px-3 py-1 text-xs text-muted-foreground">{tech}</span>
                ))}
              </div>

              <ul class="mt-4 space-y-2 text-sm text-muted-foreground">
                {project.highlights.slice(0, 2).map(point => (
                  <li class="flex gap-2">
                    <span class="mt-2 inline-block h-1.5 w-1.5 shrink-0 rounded-full bg-accent"></span>
                    <span>{point}</span>
                  </li>
                ))}
              </ul>

              <div class="mt-6 flex flex-wrap gap-3 text-sm font-semibold">
                {project.links.slice(0, 2).map(link => (
                  <a href={link.href} target="_blank" rel="noopener noreferrer" class="text-accent hover:underline">
                    {link.label}
                  </a>
                ))}
              </div>

              {(project.highlights.length > 2 || project.links.length > 2) && (
                <details class="mt-4 rounded-lg border border-border/80 bg-background/65 p-3 text-sm">
                  <summary class="cursor-pointer font-semibold text-accent">Xem chi tiết kỹ thuật</summary>

                  {project.highlights.length > 2 && (
                    <ul class="mt-3 space-y-2 text-muted-foreground">
                      {project.highlights.slice(2).map(point => (
                        <li class="flex gap-2">
                          <span class="mt-2 inline-block h-1.5 w-1.5 shrink-0 rounded-full bg-accent"></span>
                          <span>{point}</span>
                        </li>
                      ))}
                    </ul>
                  )}

                  {project.links.length > 2 && (
                    <div class="mt-3 flex flex-wrap gap-3 font-semibold">
                      {project.links.slice(2).map(link => (
                        <a href={link.href} target="_blank" rel="noopener noreferrer" class="text-accent hover:underline">
                          {link.label}
                        </a>
                      ))}
                    </div>
                  )}
                </details>
              )}
            </article>
          ))}
        </div>
      </div>
    </section>

    <section id="skills" class="reveal-block mx-auto w-full max-w-6xl px-6 py-16">
      <div class="mb-8 flex items-end justify-between gap-4">
        <div>
          <h2 class="text-3xl font-bold">Năng lực chuyên môn</h2>
          <p class="mt-2 text-muted-foreground">Các nhóm kỹ năng được sử dụng thường xuyên trong quá trình học tập và triển khai dự án.</p>
        </div>
      </div>

      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
        {skillGroups.map((group, index) => (
          <article class="neo-panel rounded-xl border border-border/90 bg-background/90 p-5 hover:border-accent/40 hover:shadow-md transition-all duration-200" style={`--stagger-index: ${index};`}>
            <h3 class="text-lg font-semibold">{group.title}</h3>
            <ul class="mt-3 space-y-2 text-sm text-muted-foreground">

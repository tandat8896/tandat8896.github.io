      { label: "Image Result", href: "https://drive.google.com/drive/folders/1oUb_0HdjAEWWK0tl9sLHoYQfvCMphqZv?hl=vi" },
    ],
  },
  {
    title: "Demand-driven Inventory Optimization (Multi-store)",

        <h2 class="text-3xl font-bold">Project Demos</h2>
        <p class="mt-2 max-w-2xl text-muted-foreground">
          Một số video đại diện cho quy trình triển khai và kiểm thử dự án.
        </p>

        <div class="mt-8 grid gap-6 lg:grid-cols-2">
          {projectDemos.map((demo, index) => (
            <article class="neo-panel video-showcase rounded-2xl border border-border bg-background p-5 sm:p-6" style={`--stagger-index: ${index};`}>

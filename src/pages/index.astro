    ],
    links: [
      { label: "GitHub", href: "https://github.com/tandat8896/sales-forecasting-end-to-end" },
      { label: "KServe Demo Video", href: "https://youtu.be/qJGMT12w4OE" },
    ],
  },
  {
    title: "Multimodal Video RAG System - AI Challenge HCM 2025",
    state: "Competition",
    role: "Data Engineering | Team: AIO_AuraQ (Reached Qualification Round 3)",
    description:
      "Xây dựng pipeline truy hồi video đa phương thức trong môi trường thi đấu, tối ưu retrieval theo từng vòng để cải thiện điểm số.",
    stack: ["OpenCV", "PyTorch", "Milvus", "Kaggle Environments"],
    highlights: [
      "Tăng 45% điểm số từ Round 2 (15.4) lên Round 3 (22.4/35).",
      "Phát triển module Keyframe Sampling và CLIP Embedding cho video search.",
    ],
    links: [
